{
  "schema_version": "1.0",
  "product_id": "realtor",
  "product_name": "RealtorTasksAI",
  "official_domain": "realtortasksai.com",
  "official_github_repo": "https://github.com/laudoluxDev/realtortasksai-mcp",
  "official_package": "@tasksai/install",
  "installer": {
    "preferred": "npm_exec",
    "npm_exec": {
      "command": "npm",
      "args": [
        "exec",
        "--package=@tasksai/install",
        "--call",
        "tasksai-install realtor --source https://github.com/laudoluxDev/realtortasksai-mcp"
      ],
      "requires": [
        "node",
        "npm"
      ]
    }
  },
  "supported_clients": [
    "claude_desktop",
    "cursor",
    "windsurf",
    "codex"
  ],
  "permissions": {
    "write_paths": {
      "macos": [
        "~/Library/Application Support/TasksAI/realtor",
        "~/Library/Application Support/Claude/claude_desktop_config.json",
        "~/.cursor/mcp.json",
        "~/.codeium/windsurf/mcp_config.json",
        "~/.codex/config.toml"
      ],
      "windows": [
        "%LOCALAPPDATA%\\TasksAI\\realtor",
        "%APPDATA%\\Claude\\claude_desktop_config.json",
        "%USERPROFILE%\\.cursor\\mcp.json",
        "%USERPROFILE%\\.codeium\\windsurf\\mcp_config.json",
        "%USERPROFILE%\\.codex\\config.toml"
      ],
      "linux": [
        "~/.local/share/TasksAI/realtor",
        "~/.config/Claude/claude_desktop_config.json",
        "~/.cursor/mcp.json",
        "~/.codeium/windsurf/mcp_config.json",
        "~/.codex/config.toml"
      ]
    },
    "environment_overrides": [
      "TASKSAI_INSTALL_DIR"
    ],
    "notes": "TASKSAI_INSTALL_DIR or --install-dir may point to an exact alternate product install directory in restricted agent environments."
  },
  "auth": {
    "method": "browser_device_flow",
    "connect_url": "https://realtortasksai.com/connect",
    "fallback": "license_key"
  },
  "security": {
    "require_domain_verification": true,
    "require_repo_verification": true,
    "disallow_arbitrary_manifest_commands": true,
    "native_installer_user_approval_required": true
  },
  "health_check": {
    "command": "npm",
    "args": [
      "exec",
      "--package=@tasksai/install",
      "--call",
      "tasksai-install realtor doctor"
    ]
  },
  "uninstall": {
    "command": "npm",
    "args": [
      "exec",
      "--package=@tasksai/install",
      "--call",
      "tasksai-install realtor uninstall"
    ]
  },
  "support": {
    "url": "https://realtortasksai.com/support",
    "email": "hello@realtortasksai.com"
  },
  "runtime": {
    "source": "shared_installer",
    "notes": "The wrapper repo provides product metadata; @tasksai/install supplies the shared MCP runtime."
  }
}
